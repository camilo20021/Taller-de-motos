# Copia este archivo como ".env" y completa tus datos reales.
# NUNCA subas el archivo ".env" real a git (ya esta ignorado).

# Clave secreta de la aplicacion (usa una cadena larga y aleatoria en produccion)
SECRET_KEY=cambia-esta-clave-super-secreta

# Base de datos. Si dejas esta linea comentada se usa un archivo SQLite
# local en la carpeta instance/ (bueno solo para probar en tu propia PC).
#
# Para usar la base de datos de Supabase (Postgres), copia el
# "Connection string" modo URI desde Supabase:
#   Project Settings -> Database -> Connection string -> URI
# y pegalo aqui. Asegurate de reemplazar [YOUR-PASSWORD] por tu clave real
# y de agregar "?sslmode=require" al final.
# DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:TU_PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require

# Configuracion de correo (para notificar al cliente cuando su moto queda "terminada")
# Con Gmail: activa verificacion en 2 pasos y genera una "contrasena de aplicacion".
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=tu_correo@gmail.com
MAIL_PASSWORD=tu_clave_de_aplicacion
MAIL_DEFAULT_SENDER=tu_correo@gmail.com

# Si pones esto en true, los correos NO se envian de verdad (util para pruebas locales)
MAIL_SUPPRESS_SEND=false

# Datos del taller (unico taller que usa este sistema) y de la cuenta
# administradora inicial. Solo se usan UNA vez, la primera vez que se
# arranca la app con la base de datos vacia, para crear ambos registros.
# Despues de eso puedes cambiar la contrasena desde la propia aplicacion.
TALLER_NOMBRE=Motos JL Racing
TALLER_NIT=
TALLER_DIRECCION=
TALLER_TELEFONO=

ADMIN_NOMBRE=Administrador
ADMIN_EMAIL=admin@motosjlracing.com
ADMIN_PASSWORD=cambiar123
